{
    "name": "laravel/nightwatch-agent",
    "version": "0.0.0",
    "type": "project",
    "description": "The official Laravel Nightwatch agent.",
    "keywords": ["laravel", "monitoring", "insights"],
    "homepage": "https://nightwatch.laravel.com",
    "license": "MIT",
    "support": {
        "docs": "https://nightwatch.laravel.com/docs",
        "issues": "https://github.com/laravel/nightwatch/issues",
        "source": "https://github.com/laravel/nightwatch"
    },
    "authors": [
        {
            "name": "Taylor Otwell",
            "email": "taylor@laravel.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-zlib": "*",
        "psr/http-message": "^1.1",
        "react/event-loop": "^1.5",
        "react/http": "^1.11",
        "react/promise": "^3.2",
        "react/socket": "^1.16",
        "react/stream": "^1.4"
    },
    "require-dev": {
        "ext-pcntl": "*",
        "evenement/evenement": "^3.0",
        "laravel/pint": "1.21.0",
        "phpstan/phpstan": "^2.1.6",
        "phpunit/phpunit": "^11.5.3",
        "symfony/process": "^7.2",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "Laravel\\NightwatchAgent\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "ci": [
            "@composer build",
            "@composer test",
            "@composer lint"
        ],
        "lint": [
            "@php vendor/bin/phpstan --memory-limit=-1 --verbose",
            "@php vendor/bin/pint --config=pint.ci.json --cache-file=.pint.ci.cache",
            "@php vendor/bin/pint --cache-file=.pint.cache"
        ],
        "test": [
            "@php vendor/bin/phpunit"
        ],
        "build": [
            "bash ./build.sh"
        ],
        "watch": [
            "npm ci",
            "node watch.js"
        ]
    },
    "config": {
        "autoloader-suffix": "zUjV6thn8dELeOw6",
        "classmap-authoritative": true,
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
